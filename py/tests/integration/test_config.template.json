{
  "dsp": {
    "enable_output": {{ enable_output | default(false) | lower }},
    "enable_streaming": {{ enable_streaming | default(false) | lower }},
    "streaming_bitrate": 128000,
    "streaming_port": {{ streaming_port | default(5001) }},
    "block_size": {{ block_size | default(4096) }},
    "sample_directory": "{{ sample_directory | default('.') }}",
    "sample_packs": []
  },
  "live": {
    "directory": ".",
    "initial_bpm": {{ initial_bpm | default(120) }}
  }
}
